source @PKGLIBDIR@/net-common

check

# If we are dealing with an instance communication interface, we need to branch
# out to the kvm-ifup-os script (this is kept for compatibility reasons for now)
if is_instance_communication_tap && [ -x "${CONF_DIR}/kvm-ifup-os" ]; then
  exec ${CONF_DIR}/kvm-ifup-os
fi


# This is only a wrapper script which will call the relevant action
# script for the given network mode.
#
# Built-in modes (bridged, routed, openvswitch) check for a user override
# in ${CONF_DIR}/network/${MODE}/ first, then fall back to the versioned
# built-in in ${PKGLIBDIR}/network/${MODE}/.
#
# The ext mode is fully user-defined: only ${CONF_DIR}/network/ext/ is
# searched, and a missing script is a hard error.
if [ "${MODE}" = "ext" ]; then
  if [ -x "${CONF_DIR}/network/${MODE}/${ACTION}" ]; then
    exec ${CONF_DIR}/network/${MODE}/${ACTION}
  else
    echo "Error: no ${ACTION} script for network type ${MODE}" \
         "found in ${CONF_DIR}/network/${MODE}/" >&2
    exit 1
  fi
fi

if [ -x "${CONF_DIR}/network/${MODE}/${ACTION}" ]; then
  exec ${CONF_DIR}/network/${MODE}/${ACTION}
elif [ -x "${PKGLIBDIR}/network/${MODE}/${ACTION}" ]; then
  exec ${PKGLIBDIR}/network/${MODE}/${ACTION}
else
  echo "Error: no ${ACTION} script for network type ${MODE} found" >&2
  exit 1
fi
